#!/usr/bin/env bash
set -euo pipefail

# Update Last Update lines before pushing
DATE=$(date -u +%F)
FILES=("LLM-D_Inference_Scheduler.md" "README.md" "LLM-D_Inference_Scheduler (Short).md")
changed=false
for f in "${FILES[@]}"; do
  if [ -f "$f" ]; then
    if grep -q '^Last Update:' "$f"; then
      # Edit in a way that preserves the inode (don't mv over the file)
      awk -v d="$DATE" '{ if ($0 ~ /^Last Update:/) { print "Last Update: " d } else { print } }' "$f" > "$f.tmp" && cat "$f.tmp" > "$f" && rm -f "$f.tmp"
      changed=true
    else
      awk -v d="$DATE" 'NR==1{print; print ""; print "Last Update: " d; next} {print}' "$f" > "$f.tmp" && cat "$f.tmp" > "$f" && rm -f "$f.tmp"
      changed=true
    fi
  fi
done

if [ "$changed" = false ]; then
  echo "No files updated."
  exit 0
fi

git add "${FILES[@]}"
if git diff --cached --quiet; then
  echo "Nothing to commit"
  exit 0
fi

git commit -m "chore: update Last Update dates (hook)"

exit 0
